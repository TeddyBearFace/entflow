# ===========================================
# Workflow Mapper - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.

# --- Database (Supabase or Neon) ---
DATABASE_URL="postgresql://user:password@host:5432/workflow_mapper?sslmode=require"

# --- HubSpot App ---
# Get these from your HubSpot developer account > Apps > Your App > Auth
HUBSPOT_CLIENT_ID="your-hubspot-client-id"
HUBSPOT_CLIENT_SECRET="your-hubspot-client-secret"
HUBSPOT_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_SECRET="generate-a-random-32-char-string-here"

# --- Encryption key for storing OAuth tokens ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY="your-64-char-hex-encryption-key"
