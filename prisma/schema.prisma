// ===========================================
// Workflow Mapper - Database Schema
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// Auth Models (NextAuth.js)
// ===========================================

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime? @map("email_verified")
  hashedPassword  String?   @map("hashed_password")
  image           String?

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  accounts        Account[]
  sessions        Session[]
  userPortals     UserPortal[]

  @@map("users")
}
model DismissedConflict {
  id         String   @id @default(cuid())
  portalId   String   @map("portal_id")
  propertyKey String  @map("property_key") // e.g. "CONTACT:lifecyclestage"
  dismissedBy String? @map("dismissed_by")
  dismissedAt DateTime @default(now()) @map("dismissed_at")

  portal     Portal   @relation(fields: [portalId], references: [id], onDelete: Cascade)

  @@unique([portalId, propertyKey])
  @@map("dismissed_conflicts")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --- Junction: which users can access which portals ---
model UserPortal {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  portalId  String   @map("portal_id")
  role      String   @default("owner") // "owner" or "member"
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  portal    Portal   @relation(fields: [portalId], references: [id], onDelete: Cascade)

  @@unique([userId, portalId])
  @@map("user_portals")
}

// ===========================================
// App Models
// ===========================================

// --- Portal: A connected HubSpot account ---
model Portal {
  id              String     @id @default(cuid())
  hubspotPortalId String     @unique @map("hubspot_portal_id")
  name            String?

  // OAuth tokens (stored encrypted - see lib/encryption.ts)
  accessToken     String     @map("access_token")
  refreshToken    String     @map("refresh_token")
  tokenExpiresAt  DateTime   @map("token_expires_at")

  // Sync state
  lastSyncedAt    DateTime?  @map("last_synced_at")
  syncStatus      SyncStatus @default(NEVER_SYNCED) @map("sync_status")
  syncProgress    Int        @default(0) @map("sync_progress")
  syncTotal       Int        @default(0) @map("sync_total")
  syncMessage     String?    @map("sync_message")

  // Subscription
  planTier        PlanTier   @default(FREE) @map("plan_tier")
  stripeCustomerId String?   @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")
  stripeCurrentPeriodEnd DateTime? @map("stripe_current_period_end")

  // Auto-sync
  autoSyncEnabled Boolean    @default(false) @map("auto_sync_enabled")
  autoSyncInterval Int       @default(360) @map("auto_sync_interval")

  // Flow Timeline
  flowTimeline        Json?      @map("flow_timeline")
  flowTimelineAt      DateTime?  @map("flow_timeline_at")

  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relations
  userPortals     UserPortal[]
  dismissedConflicts  DismissedConflict[]
  workflows       Workflow[]
  dependencies    Dependency[]
  conflicts       Conflict[]
  syncLogs        SyncLog[]
  propertyIndex   PropertyIndex[]
  customNodes     CustomNode[]
  tags            Tag[]

  @@map("portals")
}

// --- Workflow: A single HubSpot automation workflow ---
model Workflow {
  id                String         @id @default(cuid())
  portalId          String         @map("portal_id")
  hubspotFlowId     String         @map("hubspot_flow_id")

  name              String
  description       String?
  objectType        ObjectType     @map("object_type")
  status            WorkflowStatus @default(ACTIVE)
  flowType          String?        @map("flow_type")

  enrollmentCriteria Json?         @map("enrollment_criteria")
  actions           Json?
  dataSources       Json?          @map("data_sources")

  actionCount       Int            @default(0) @map("action_count")
  enrollmentCount   Int?           @map("enrollment_count")

  hubspotCreatedAt  DateTime?      @map("hubspot_created_at")
  hubspotUpdatedAt  DateTime?      @map("hubspot_updated_at")

  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  portal            Portal         @relation(fields: [portalId], references: [id], onDelete: Cascade)

  sourceDependencies Dependency[]  @relation("SourceWorkflow")
  targetDependencies Dependency[]  @relation("TargetWorkflow")

  conflictWorkflows  ConflictWorkflow[]
  workflowTags       WorkflowTag[]

  @@unique([portalId, hubspotFlowId])
  @@index([portalId])
  @@index([objectType])
  @@index([status])
  @@map("workflows")
}

model Tag {
  id          String        @id @default(cuid())
  portalId    String        @map("portal_id")
  name        String
  color       String        @default("#6366f1")

  createdAt   DateTime      @default(now()) @map("created_at")

  portal      Portal        @relation(fields: [portalId], references: [id], onDelete: Cascade)
  workflowTags WorkflowTag[]

  @@unique([portalId, name])
  @@index([portalId])
  @@map("tags")
}

model WorkflowTag {
  id          String   @id @default(cuid())
  workflowId  String   @map("workflow_id")
  tagId       String   @map("tag_id")

  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([workflowId, tagId])
  @@map("workflow_tags")
}

model Dependency {
  id                String         @id @default(cuid())
  portalId          String         @map("portal_id")

  sourceWorkflowId  String         @map("source_workflow_id")
  targetWorkflowId  String?        @map("target_workflow_id")

  type              DependencyType
  severity          Severity       @default(INFO)

  detail            Json
  description       String?

  createdAt         DateTime       @default(now()) @map("created_at")

  portal            Portal         @relation(fields: [portalId], references: [id], onDelete: Cascade)
  sourceWorkflow    Workflow        @relation("SourceWorkflow", fields: [sourceWorkflowId], references: [id], onDelete: Cascade)
  targetWorkflow    Workflow?       @relation("TargetWorkflow", fields: [targetWorkflowId], references: [id], onDelete: Cascade)

  @@index([portalId])
  @@index([sourceWorkflowId])
  @@index([targetWorkflowId])
  @@index([type])
  @@map("dependencies")
}

model Conflict {
  id              String         @id @default(cuid())
  portalId        String         @map("portal_id")

  type            ConflictType
  severity        Severity       @default(WARNING)
  description     String

  detail          Json

  resolvedAt      DateTime?      @map("resolved_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  portal          Portal         @relation(fields: [portalId], references: [id], onDelete: Cascade)
  workflows       ConflictWorkflow[]

  @@index([portalId])
  @@index([type])
  @@index([severity])
  @@map("conflicts")
}

model ConflictWorkflow {
  conflictId  String   @map("conflict_id")
  workflowId  String   @map("workflow_id")

  conflict    Conflict @relation(fields: [conflictId], references: [id], onDelete: Cascade)
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@id([conflictId, workflowId])
  @@map("conflict_workflows")
}

model PropertyIndex {
  id              String   @id @default(cuid())
  portalId        String   @map("portal_id")

  propertyName    String   @map("property_name")
  objectType      String   @map("object_type")

  readByWorkflows  String[] @map("read_by_workflows")
  writtenByWorkflows String[] @map("written_by_workflows")

  createdAt       DateTime @default(now()) @map("created_at")

  portal          Portal   @relation(fields: [portalId], references: [id], onDelete: Cascade)

  @@unique([portalId, propertyName, objectType])
  @@index([portalId])
  @@map("property_index")
}

model SyncLog {
  id              String     @id @default(cuid())
  portalId        String     @map("portal_id")

  status          SyncStatus
  workflowCount   Int?       @map("workflow_count")
  dependencyCount Int?       @map("dependency_count")
  conflictCount   Int?       @map("conflict_count")

  durationMs      Int?       @map("duration_ms")
  error           String?

  startedAt       DateTime   @default(now()) @map("started_at")
  completedAt     DateTime?  @map("completed_at")

  portal          Portal     @relation(fields: [portalId], references: [id], onDelete: Cascade)

  @@index([portalId])
  @@index([startedAt])
  @@map("sync_logs")
}

model MarketingEmail {
  id              String    @id @default(cuid())
  portalId        String    @map("portal_id")
  hubspotEmailId  String    @map("hubspot_email_id")
  name            String
  subject         String?
  fromName        String?   @map("from_name")
  fromEmail       String?   @map("from_email")
  replyTo         String?   @map("reply_to")
  previewText     String?   @map("preview_text")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([portalId, hubspotEmailId])
  @@index([portalId])
  @@map("marketing_emails")
}

model CrmList {
  id              String    @id @default(cuid())
  portalId        String    @map("portal_id")
  hubspotListId   String    @map("hubspot_list_id")
  name            String

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([portalId, hubspotListId])
  @@index([portalId])
  @@map("crm_lists")
}

model Pipeline {
  id              String          @id @default(cuid())
  portalId        String          @map("portal_id")
  hubspotPipelineId String        @map("hubspot_pipeline_id")
  objectType      String          @map("object_type")
  label           String
  displayOrder    Int             @default(0) @map("display_order")

  stages          PipelineStage[]

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([portalId, hubspotPipelineId])
  @@index([portalId])
  @@map("pipelines")
}

model PipelineStage {
  id              String    @id @default(cuid())
  pipelineId      String    @map("pipeline_id")
  hubspotStageId  String    @map("hubspot_stage_id")
  label           String
  displayOrder    Int       @default(0) @map("display_order")
  metadata        Json?

  pipeline        Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, hubspotStageId])
  @@map("pipeline_stages")
}

model CustomNode {
  id              String    @id @default(cuid())
  portalId        String    @map("portal_id")

  label           String
  nodeType        String    @default("stage") @map("node_type")
  color           String    @default("#6366f1")
  icon            String?
  description     String?
  textContent     String?   @map("text_content") @db.Text
  fontSize        Int?      @map("font_size")
  fontWeight      String?   @map("font_weight")
  fontStyle       String?   @map("font_style")
  textAlign       String?   @map("text_align")
  zIndex          Int       @default(0) @map("z_index")

  positionX       Float     @default(0) @map("position_x")
  positionY       Float     @default(0) @map("position_y")
  width           Float?
  height          Float?

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  portal          Portal    @relation(fields: [portalId], references: [id], onDelete: Cascade)

  @@index([portalId])
  @@map("custom_nodes")
}

model CustomEdge {
  id              String    @id @default(cuid())
  portalId        String    @map("portal_id")
  sourceNodeId    String    @map("source_node_id")
  targetNodeId    String    @map("target_node_id")
  label           String?
  color           String    @default("#6366f1")
  edgeType        String    @default("default") @map("edge_type")
  animated        Boolean   @default(false)
  markerType      String    @default("arrow") @map("marker_type") // arrow, reverse, bidirectional, none

  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([portalId])
  @@map("custom_edges")
}

model NodePosition {
  id              String    @id @default(cuid())
  portalId        String    @map("portal_id")
  nodeId          String    @map("node_id")
  positionX       Float     @map("position_x")
  positionY       Float     @map("position_y")

  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([portalId, nodeId])
  @@map("node_positions")
}

// --- Enums ---

enum SyncStatus {
  NEVER_SYNCED
  SYNCING
  COMPLETED
  FAILED
}

enum PlanTier {
  FREE
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

enum ObjectType {
  CONTACT
  DEAL
  COMPANY
  TICKET
  CUSTOM
  UNKNOWN
}

enum WorkflowStatus {
  ACTIVE
  INACTIVE
  ERRORING
}

enum DependencyType {
  PROPERTY_READ
  PROPERTY_WRITE
  CROSS_ENROLLMENT
  LIST_REFERENCE
  EMAIL_SEND
  WEBHOOK
  DELAY_CHAIN
}

enum Severity {
  INFO
  WARNING
  CRITICAL
}

enum ConflictType {
  PROPERTY_WRITE_COLLISION
  CIRCULAR_DEPENDENCY
  INACTIVE_REFERENCE
  EMAIL_OVERLAP
  ORPHANED_ENROLLMENT
}

model WorkflowSnapshot {
  id                String    @id @default(cuid())
  portalId          String    @map("portal_id")
  workflowId        String    @map("workflow_id")
  hubspotFlowId     String    @map("hubspot_flow_id")
  name              String
  status            String
  actionCount       Int       @map("action_count")
  actionsHash       String    @map("actions_hash")
  enrollmentHash    String    @map("enrollment_hash")
  actionsJson       String    @map("actions_json") @db.Text
  enrollmentJson    String?   @map("enrollment_json") @db.Text
  syncLogId         String?   @map("sync_log_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([portalId, workflowId])
  @@index([portalId, createdAt])
  @@map("workflow_snapshots")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  portalId  String?  @map("portal_id")
  userId    String?  @map("user_id")
  event     String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([event, createdAt])
  @@index([portalId])
  @@index([userId])
  @@map("analytics_events")
}

model ChangelogEntry {
  id                String    @id @default(cuid())
  portalId          String    @map("portal_id")
  workflowId        String?   @map("workflow_id")
  hubspotFlowId     String?   @map("hubspot_flow_id")
  workflowName      String    @map("workflow_name")
  changeType        String    @map("change_type")
  severity          String    @default("INFO")
  summary           String
  details           String?   @db.Text
  previousValue     String?   @map("previous_value") @db.Text
  newValue          String?   @map("new_value") @db.Text
  syncLogId         String?   @map("sync_log_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([portalId, createdAt])
  @@index([portalId, workflowId])
  @@index([portalId, changeType])
  @@map("changelog_entries")
}
